# MyWisata Application — Environment Configuration Example
# Copy this file to .env and fill in your values
# OR configure directly in app/config/config.php and app/config/database.php
# 
# CATATAN PENTING:
# Untuk konfigurasi lengkap multi-environment (Linux/Windows), 
# gunakan file: prompting/config.json
# File config.json berisi semua konfigurasi untuk development di multiple komputer

# App Settings
APP_ENV=development
APP_DEBUG=true
APP_NAME="MyWisata Application"
BASE_URL=http://localhost/mywisata/

# Database
DB_HOST=localhost
DB_NAME=mywisata
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Security
# CSRF_TOKEN is auto-generated per session, do not set manually

# Upload
MAX_UPLOAD_SIZE=5242880

# Email (for notifications)
MAIL_FROM=admin@mywisata.com
MAIL_FROM_NAME="MyWisata App"

# Logging
LOG_PATH=/opt/lampp/htdocs/mywisata/logs

# Multi-Environment Config
# Untuk konfigurasi lengkap yang mendukung Linux & Windows,
# lihat file: prompting/config.json
# 
# File config.json berisi:
# - Environment-specific config (local, staging, production)
# - OS-specific paths (Linux/Windows)
# - Database credentials per environment
# - API keys untuk third-party services
# - System passwords (SUDO, phpMyAdmin)
# - Permissions untuk auto-execution
# - Development preferences
