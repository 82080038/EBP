root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.php]
indent_style = space
indent_size = 4
max_line_length = 120

[*.js]
indent_style = space
indent_size = 2
max_line_length = 120

[*.css]
indent_style = space
indent_size = 2
max_line_length = 120

[*.html]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.sql]
indent_style = space
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[.htaccess]
indent_style = space
indent_size = 2
