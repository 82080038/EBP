# FRED API Key (gratis) - daftar di https://fred.stlouisfed.org
FRED_API_KEY=

# Alpha Vantage API Key (gratis, 500 req/day) - daftar di https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub API Key (gratis, 60 req/min) - daftar di https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# NewsAPI API Key (gratis, 100 req/day) - daftar di https://newsapi.org/register
NEWSAPI_API_KEY=your_newsapi_key_here

# Reddit API (Gratis - perlu setup app di https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SahamApp/1.0

# MLflow Tracking (opsional) - default: file-based local store
MLFLOW_TRACKING_URI=file:///app/mlruns

# Logging
LOG_LEVEL=INFO

# API Authentication (untuk FastAPI)
API_KEY=dev_api_key_change_in_production

# Database (opsional) - kosongkan untuk menggunakan SQLite (default)
# PostgreSQL + TimescaleDB untuk production:
# DATABASE_URL=postgresql://saham:saham_dev@localhost:5432/saham
DATABASE_URL=

# PostgreSQL Environment Variables (untuk Docker Compose)
POSTGRES_DB=saham
POSTGRES_USER=saham
POSTGRES_PASSWORD=change_this_password_in_production

# Redis Cache (opsional) - kosongkan untuk menonaktifkan caching
# Redis untuk caching + Celery broker:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# Celery (opsional) - menggunakan REDIS_URL sebagai default
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Telegram Bot (opsional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email Notification (opsional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com

# Local LLM via Ollama (opsional, gratis, tanpa API key)
# Install: https://ollama.ai
# Pull model: ollama pull phi3 (atau llama3, mistral, qwen2.5)
# Run: ollama serve
# Kosongkan untuk menggunakan InAppCommentary (built-in fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3
