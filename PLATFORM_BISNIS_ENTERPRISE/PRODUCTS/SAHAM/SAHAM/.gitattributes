# Normalize line endings across Linux/macOS/Windows
* text=auto

# Source & config files -> LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf

# Windows batch files -> CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pkl binary
*.db binary
